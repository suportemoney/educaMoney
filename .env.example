# PostgreSQL
POSTGRES_DB=educamoney
POSTGRES_USER=educamoney
POSTGRES_PASSWORD=educamoney_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# WhatsApp (placeholder — compra fora do sistema)
WHATSAPP_URL=https://wa.me/5500000000000

# Portal do aluno (dev path; prod = https://aluno.educamoney.com.br/)
ALUNO_PORTAL_URL=http://localhost/portal/

# E-mail (opcional no .env — preferência: configurar em Painel → Integração → Novo e-mail)
EMAIL_ENABLED=0
EMAIL_HOST=smtp.exemplo.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=EducaMoney <noreply@educamoney.local>
SECRETARIA_NOTIFY_EMAIL=secretaria@educamoney.local
